/*
 * nucleo_l476rg.overlay — Mapa de pines del hardware y configuración de periféricos.
 *
 * ÚLTIMA REVISIÓN: reasignación completa de pines (ver docs/04-design-decisions.md,
 * mapa consolidado en checkpoint.md Sección 1.2 si aún no está formalizado).
 *
 * Resumen del mapa actual:
 *   - ADC (NTC):              PA0, ANALOG
 *   - PWM ventilador:         PB0, AF2 (TIM3_CH3)
 *   - Registro de desplazamiento (SN74HC595N): PA5 (SCK), PA6 (LATCH), PA7 (MOSI), AF5 — SPI1
 *   - OLED (SSD1306):         PC0 (SCL), PC1 (SDA), AF4 — I2C3
 *   - ESP32 (UART):           PC10 (TX), PC11 (RX), AF7 — USART3
 *   - Teclado filas:          PC7 (R0), PA9 (R1), PA8 (R2), PB10 (R3)
 *   - Teclado columnas:       PB4 (C0), PB5 (C1), PB3 (C2), PA10 (C3)
 *   - Botón de apagado:       PC3 (EXTI, debounce por software en el driver)
 *   - Keep-alive calentador:  PA4
 *
 * Pines evitados a propósito (no los uses aunque parezcan libres):
 *   - PA13 / PA14: son SWDIO/SWCLK — reconfigurarlos como GPIO/SPI puede dejar
 *     la placa sin poder reprogramarse por USB.
 *   - PC13: es el mismo pin del botón de usuario (B1) de la Nucleo. Se usa
 *     internamente en el alias "sw0" que consume power_status_manager.c — abajo
 *     se repuntó ese alias hacia el nuevo botón de PC3 para no tocar ese .c.
 *
 * === CÓMO INTERCAMBIAR FILAS POR COLUMNAS DEL TECLADO ===
 * El driver (matrix_keypad.c) lee los pines por NOMBRE de nodo DeviceTree
 * (row_0..row_3, col_0..col_3), nunca por puerto/pin fijo. Para intercambiar
 * qué grupo físico de 4 pines actúa como filas y cuál como columnas, edita
 * ÚNICAMENTE los bloques "keypad_rows" y "keypad_cols" de abajo — no se toca
 * ningún archivo .c.
 *
 * === CÓMO CAMBIAR PULL-UP POR PULL-DOWN EN LAS COLUMNAS ===
 * Cada columna tiene hoy la bandera GPIO_PULL_UP combinada con GPIO_ACTIVE_LOW
 * (reposo en HIGH, presionado se lee en LOW). Para usar pull-down en su lugar,
 * cambia esas dos banderas por GPIO_PULL_DOWN y GPIO_ACTIVE_HIGH en cada
 * col_N de abajo (reposo en LOW, presionado se lee en HIGH) — y ajusta el
 * cableado físico para que las filas exciten hacia 3.3V en vez de hacia GND.
 * El driver no necesita cambios: gpio_pin_get_dt() ya respeta la polaridad
 * declarada aquí.
 */

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	zephyr,user {
		io-channels = <&adc1 5>;
		pwms        = <&pwm3 3 PWM_KHZ(25) PWM_POLARITY_NORMAL>;
	};

	/* Botón de apagado dedicado, PC3. Se expone también como alias "sw0" para
	 * que power_status_manager.c (que usa DT_ALIAS(sw0)) siga funcionando sin
	 * que se le toque una sola línea de código. */
	aliases {
		sw0 = &shutdown_button;
	};

	shutdown_btn {
		compatible = "gpio-keys";
		shutdown_button: shutdown_0 {
			gpios = <&gpioc 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Shutdown button";
		};
	};

	/* GPIO de keep-alive hacia la planta térmica externa simulada. Ya no tiene
	 * ningún LED "espejo" asociado (se eliminó del esquema de LEDs); esta es la
	 * única señal real de autorización. */
	heater_ctrl {
		compatible = "gpio-leds";
		heater_pin: heater_0 { gpios = <&gpioa 4 GPIO_ACTIVE_HIGH>; label = "Heater keep-alive"; };
	};

	/* LATCH del registro de desplazamiento. No es parte del protocolo SPI en
	 * sí — es un GPIO simple que shift_register.c pulsa manualmente (flanco
	 * de subida) después de sacar los 8 bits por MOSI, tal como indica el
	 * datasheet del SN74HC595N para el pin RCLK. Por eso se expone como
	 * gpio-leds normal, igual que heater_pin, y NO como cs-gpios de &spi1. */
	shiftreg_ctrl {
		compatible = "gpio-leds";
		shiftreg_latch: shiftreg_latch_0 { gpios = <&gpioa 6 GPIO_ACTIVE_HIGH>; label = "Shift register LATCH"; };
	};

	/* Filas y columnas del teclado matricial 4x4. Ver notas de cabecera sobre
	 * cómo intercambiar filas/columnas y pull-up/pull-down. */
	keypad_rows {
		compatible = "gpio-keys";
		row_0: row_0 { gpios = <&gpioc 7  GPIO_ACTIVE_HIGH>; };
		row_1: row_1 { gpios = <&gpioa 9  GPIO_ACTIVE_HIGH>; };
		row_2: row_2 { gpios = <&gpioa 8  GPIO_ACTIVE_HIGH>; };
		row_3: row_3 { gpios = <&gpiob 10 GPIO_ACTIVE_HIGH>; };
	};

	keypad_cols {
		compatible = "gpio-keys";
		col_0: col_0 { gpios = <&gpiob 4  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
		col_1: col_1 { gpios = <&gpiob 5  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
		col_2: col_2 { gpios = <&gpiob 3  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
		col_3: col_3 { gpios = <&gpioa 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; };
	};
};

/* ── SECCIÓN PINCTRL ────────────────────────────────────────────────────── */
&pinctrl {
	ntc_adc_pins: ntc_adc_pins {
		pinmux = <STM32_PINMUX('A', 0, ANALOG)>;
	};

	fan_pwm_pins: fan_pwm_pins {
		pinmux = <STM32_PINMUX('B', 0, AF2)>;
	};

	/* ¡NUEVO FORMATO!
	Cada pin de SPI es su propio nodo independiente */
	spi1_sck_pa5: spi1_sck_pa5 {
		pinmux = <STM32_PINMUX('A', 5, AF5)>;
	};

	spi1_mosi_pa7: spi1_mosi_pa7 {
		pinmux = <STM32_PINMUX('A', 7, AF5)>;
	};

	/* El LATCH (PA6) no es parte del protocolo SPI en sí — es un GPIO simple
	 * que el driver del registro pulsa manualmente después de cada trama de
	 * 8 bits, por eso NO lleva pinmux de periférico aquí; se configura como
	 * GPIO normal directamente en el driver (drivers/shift_register.c). */


	/* ¡NUEVO FORMATO!
	Cada pin de I2C es su propio nodo independiente */
	i2c3_scl_pc0: i2c3_scl_pc0 {
		pinmux = <STM32_PINMUX('C', 0, AF4)>;
		bias-pull-up;
		drive-open-drain;
	};

	i2c3_sda_pc1: i2c3_sda_pc1 {
		pinmux = <STM32_PINMUX('C', 1, AF4)>;
		bias-pull-up;
		drive-open-drain;
	};


	/* ¡NUEVO FORMATO!
	Cada pin de USART es su propio nodo independiente */
	usart3_tx_pc10: usart3_tx_pc10 {
		pinmux = <STM32_PINMUX('C', 10, AF7)>;
	};

	usart3_rx_pc11: usart3_rx_pc11 {
		pinmux = <STM32_PINMUX('C', 11, AF7)>;
	};
};

/* ── PERIFÉRICOS ────────────────────────────────────────────────────────── */

&adc1 {
	pinctrl-0 = <&ntc_adc_pins>;
	#address-cells = <1>;
	#size-cells = <0>;

	channel@5 {
		reg = <5>;
		zephyr,gain             = "ADC_GAIN_1";
		zephyr,reference        = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution       = <12>;
	};
};

&timers3 {
	status = "okay";
	st,prescaler = <0>;
	pwm3: pwm {
		status = "okay";
		pinctrl-0     = <&fan_pwm_pins>;
		pinctrl-names = "default";
	};
};

/* Registro de desplazamiento — SPI1 físico (ver aviso de nombre en cabecera).
 * MOSI únicamente, sin MISO (el 74HC595 no envía nada de vuelta) ni NSS por
 * hardware (el LATCH se maneja manualmente como GPIO, no como NSS de SPI). */
/* Registro de desplazamiento — SPI1 físico */

&spi1 {
	/* CORRECCIÓN: Apuntamos a los dos nodos independientes que creaste */
	pinctrl-0 = <&spi1_sck_pa5 &spi1_mosi_pa7>;
	pinctrl-names = "default";
	status = "okay";
	/* Sin cs-gpios: el LATCH se maneja a mano desde shift_register.c */
};

&spi2 {
	status = "disabled";
};

&usart1 {
	status = "disabled"; /* Liberado — PA9/PA10 ahora son filas/columnas del teclado */
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pc10 &usart3_rx_pc11>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c1 {
	status = "disabled"; /* Liberado — el bus real ahora es I2C3 (PC0/PC1) */
};

&i2c3 {
	pinctrl-0 = <&i2c3_scl_pc0 &i2c3_sda_pc1>;
	pinctrl-names = "default";
	status = "okay";

	ssd1306: ssd1306@3c {
		compatible        = "solomon,ssd1306";
		reg               = <0x3c>;
		width             = <128>;
		height            = <64>;
		segment-offset    = <0>;
		page-offset       = <0>;
		display-offset    = <0>;
		multiplex-ratio   = <63>;
		segment-remap;
		com-invdir;
		prechargep        = <0x22>;
		status            = "okay";
	};
};
